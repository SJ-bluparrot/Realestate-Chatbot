{
  "info": {
    "name": "new",
    "description": "Postman collection for Inframantra chatbot conversation API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "session_id",
      "value": "postman-session-001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Check API status and Redis connectivity."
      }
    },
    {
      "name": "Talk To Chatbot",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"Hi, I want to explore luxury apartments in Gurugram\",\n  \"session_id\": \"{{session_id}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/chat",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "chat"
          ]
        },
        "description": "Main endpoint to converse with the chatbot."
      }
    },
    {
      "name": "Talk To Chatbot (Hindi)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"Hanji mujhe investment ke liye options batao\",\n  \"session_id\": \"{{session_id}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/chat",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "chat"
          ]
        },
        "description": "Example Hindi chat message."
      }
    },
    {
      "name": "Reset Chat Session",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"reset\",\n  \"session_id\": \"{{session_id}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/chat",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "chat"
          ]
        },
        "description": "Clears session history and starts fresh."
      }
    },
    {
      "name": "Capture Contact",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Sam\",\n  \"phone\": \"9876543210\",\n  \"source\": \"widget\",\n  \"session_id\": \"{{session_id}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/capture-contact",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "capture-contact"
          ]
        },
        "description": "Stores lead contact details collected during chat."
      }
    }
  ]
}
